    EXEC('
        create view "dbo"."int_sales_enriched__dbt_tmp" as SELECT

    s.order_number,
    s.order_date,
    s.sales_amount,
    s.quantity,
    s.price,

    c.customer_id,

    p.product_name,
    p.category,
    p.subcategory

FROM "DataWarehouse"."dbo"."stg_sales" s

LEFT JOIN "DataWarehouse"."dbo"."stg_customers" c
    ON s.customer_key = c.customer_key

LEFT JOIN "DataWarehouse"."dbo"."stg_products" p
    ON s.product_key = p.product_key;
    ')


