            schema_name,
            principal_name,
            table_type
        from
            views_with_metadata
        join principals on views_with_metadata.owner_principal_id = principals.principal_id
    ),

    cols as (

        select
            c.object_id,
            c.name as column_name,
            c.column_id as column_index,
            t.name as column_type
        from sys.columns as c with (nolock)
        left join sys.types as t on c.system_type_id = t.system_type_id
    )

    select
        DB_NAME() as table_database,
        tv.schema_name as table_schema,
        tv.table_name,
        tv.table_type,
        null as table_comment,
        tv.principal_name as table_owner,
        cols.column_name,
        cols.column_index,
        cols.column_type,
        null as column_comment
    from tables_and_views tv
    join cols on tv.object_id = cols.object_id
    where (
                (
                    upper(tv.schema_name) = upper('dbo')
                    and upper(tv.table_name) = upper('stg_customers')
                )
             or 
                (
                    upper(tv.schema_name) = upper('dbo')
                    and upper(tv.table_name) = upper('stg_products')
                )
             or 
                (
                    upper(tv.schema_name) = upper('dbo')
                    and upper(tv.table_name) = upper('fct_sales_summary')
                )
             or 
                (
                    upper(tv.schema_name) = upper('dbo')
                    and upper(tv.table_name) = upper('int_sales_enriched')
                )
             or 
                (
                    upper(tv.schema_name) = upper('dbo')
                    and upper(tv.table_name) = upper('stg_sales')
                )
             or 
                (
                    upper(tv.schema_name) = upper('Gold')
                    and upper(tv.table_name) = upper('fact_sales')
                )
             or 
                (
                    upper(tv.schema_name) = upper('Gold')
                    and upper(tv.table_name) = upper('dim_customers')
                )
             or 
                (
                    upper(tv.schema_name) = upper('Gold')
                    and upper(tv.table_name) = upper('dim_products')
                )
            )

    order by column_index
    
    OPTION (LABEL = 'dbt-sqlserver');

